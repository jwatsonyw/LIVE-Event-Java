package lab3;

import java.util.Scanner;

public class Canteen {

	public static void main(String[] args) {
		
		String mainCourse = getString("Which main dish would you like? Chicken, Fish or Vegitarian?");
		System.out.println(mainCourse);
	
		String Potatoes = getString("How many potatoes would you like?");
		System.out.println(Potatoes);
		
		String Brussels = getString("How many potatoes sprots would you like?");
		System.out.println(Brussels);
		
		System.out.println("Hello, your lunch is " + mainCourse "with" +","+ Potatoes +","+ Brussels);
		
	}
	
		public static String getString(String prompt) {
		System.out.printf(prompt + ":");
		Scanner s = new Scanner(System.in);
		return s.nextLine();
		
	}	
	
	
}
	
